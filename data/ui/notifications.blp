using Gtk 4.0;
using Astal 4.0;

template $VanityNotifications: Astal.Window {
  styles [
    "vanity_notifications"
  ]

  title: "VanityNotifications";
  keymode: none;
  margin-top: 15;
  margin-bottom: 15;

  Box {
    orientation: vertical;
    margin-top: 15;
    margin-bottom: 15;
    margin-start: 15;
    margin-end: 15;

    ListBox notifications {
      styles [
        "notifications"
      ]

      vexpand: true;
    }
  }
}
